rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAnonymousProvider() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function hasLinkedEmail(email) {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email == email;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function currentUserExists() {
      return isSignedIn() && exists(currentUserPath());
    }

    function currentUser() {
      return get(currentUserPath());
    }

    function userAfter(uid) {
      return getAfter(/databases/$(database)/documents/users/$(uid));
    }

    function companyAfter(companyId) {
      return getAfter(/databases/$(database)/documents/companies/$(companyId));
    }

    function isAdmin() {
      return currentUserExists()
        && currentUser().data.role == 'admin'
        && currentUser().data.accountStatus == 'active';
    }

    function isCandidate() {
      return currentUserExists()
        && currentUser().data.role == 'candidate'
        && currentUser().data.accountStatus == 'active';
    }

    function isCompanyUser() {
      return currentUserExists()
        && currentUser().data.role == 'company'
        && currentUser().data.accountStatus == 'active'
        && currentUser().data.companyId is string;
    }

    function belongsToCompany(companyId) {
      return isCompanyUser()
        && currentUser().data.companyId == companyId;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && isAnonymousProvider()
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'role',
          'companyId',
          'CompanyDisplayname',
          'displayName',
          'firstName',
          'lastName',
          'accountStatus',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.displayName is string
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.role in ['candidate', 'company']
        && request.resource.data.accountStatus == 'pending'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (
          (
            request.resource.data.role == 'candidate'
            && request.resource.data.companyId == null
            && request.resource.data.CompanyDisplayname == null
          )
          ||
          (
            request.resource.data.role == 'company'
            && request.resource.data.companyId is string
            && request.resource.data.companyId.size() > 0
            && request.resource.data.CompanyDisplayname is string
            && request.resource.data.CompanyDisplayname.size() > 0
            && companyAfter(request.resource.data.companyId).data.companyId
              == request.resource.data.companyId
            && companyAfter(request.resource.data.companyId).data.companyName
              == request.resource.data.CompanyDisplayname
          )
        );

      allow update: if isOwner(uid)
        && resource.data.uid == uid
        && request.resource.data.uid == uid
        && resource.data.role == request.resource.data.role
        && resource.data.companyId == request.resource.data.companyId
        && resource.data.CompanyDisplayname == request.resource.data.CompanyDisplayname
        && resource.data.displayName == request.resource.data.displayName
        && resource.data.firstName == request.resource.data.firstName
        && resource.data.lastName == request.resource.data.lastName
        && resource.data.createdAt == request.resource.data.createdAt
        && resource.data.accountStatus == 'pending'
        && request.resource.data.accountStatus == 'active'
        && request.resource.data.email is string
        && hasLinkedEmail(request.resource.data.email)
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'email',
          'accountStatus',
          'updatedAt'
        ]);

      allow delete: if isOwner(uid)
        && resource.data.accountStatus == 'pending';
    }

    match /candidateProfiles/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && isAnonymousProvider()
        && request.resource.data.ownerId == uid
        && request.resource.data.reviewStatus == 'draft'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && userAfter(uid).data.uid == uid
        && userAfter(uid).data.role == 'candidate'
        && userAfter(uid).data.accountStatus == 'pending';

      allow update: if isOwner(uid)
        && isCandidate()
        && resource.data.ownerId == uid
        && request.resource.data.ownerId == uid
        && request.resource.data.reviewStatus == resource.data.reviewStatus
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'apprenticeshipProfession',
          'specialisation',
          'skills',
          'location',
          'careerGoals',
          'updatedAt'
        ]);

      allow delete: if isOwner(uid)
        && resource.data.ownerId == uid
        && resource.data.reviewStatus == 'draft'
        && currentUserExists()
        && currentUser().data.accountStatus == 'pending';
    }

    match /companies/{companyId} {
      allow read: if belongsToCompany(companyId) || isAdmin();

      allow create: if isSignedIn()
        && isAnonymousProvider()
        && request.resource.data.keys().hasOnly([
          'companyId',
          'companyName',
          'description',
          'location',
          'reviewStatus',
          'createdBy',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.companyId == companyId
        && request.resource.data.companyName is string
        && request.resource.data.companyName.size() > 0
        && request.resource.data.description is string
        && request.resource.data.location is string
        && request.resource.data.reviewStatus == 'draft'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && userAfter(request.auth.uid).data.uid == request.auth.uid
        && userAfter(request.auth.uid).data.role == 'company'
        && userAfter(request.auth.uid).data.companyId == companyId
        && userAfter(request.auth.uid).data.CompanyDisplayname
          == request.resource.data.companyName
        && userAfter(request.auth.uid).data.accountStatus == 'pending';

      allow update: if belongsToCompany(companyId)
        && resource.data.companyId == companyId
        && request.resource.data.companyId == companyId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.reviewStatus == resource.data.reviewStatus
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'description',
          'location',
          'updatedAt'
        ]);

      allow delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid
        && resource.data.reviewStatus == 'draft'
        && currentUserExists()
        && currentUser().data.role == 'company'
        && currentUser().data.companyId == companyId
        && currentUser().data.accountStatus == 'pending';
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}