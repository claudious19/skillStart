rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidRole(role) {
      return role in ['candidate', 'company', 'admin'];
    }

    function isValidReviewStatus(status) {
      return status in ['draft', 'pending', 'approved', 'rejected', 'needs_changes'];
    }

    function isAnonymousProvider() {
      return request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isPasswordProvider() {
      return request.auth.token.firebase.sign_in_provider == 'password';
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && isAnonymousProvider()
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.role in ['candidate', 'company']
        && request.resource.data.accountStatus == 'pending'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if isOwner(uid)
        && isPasswordProvider()
        && resource.data.uid == uid
        && resource.data.role == request.resource.data.role
        && resource.data.accountStatus == 'pending'
        && request.resource.data.accountStatus == 'active'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email', 'accountStatus', 'updatedAt'])
        && request.resource.data.email is string
        && request.resource.data.updatedAt is timestamp;

      allow delete: if isOwner(uid)
        && isAnonymousProvider()
        && resource.data.accountStatus == 'pending';
    }

    match /candidateProfiles/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && isAnonymousProvider()
        && request.resource.data.ownerId == uid
        && request.resource.data.reviewStatus == 'draft'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if isOwner(uid)
        && resource.data.ownerId == uid
        && request.resource.data.ownerId == uid
        && isValidReviewStatus(request.resource.data.reviewStatus);

      allow delete: if isOwner(uid)
        && isAnonymousProvider()
        && resource.data.ownerId == uid
        && resource.data.reviewStatus == 'draft';
    }

    match /companyProfiles/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && isAnonymousProvider()
        && request.resource.data.ownerId == uid
        && request.resource.data.reviewStatus == 'draft'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if isOwner(uid)
        && resource.data.ownerId == uid
        && request.resource.data.ownerId == uid
        && isValidReviewStatus(request.resource.data.reviewStatus);

      allow delete: if isOwner(uid)
        && isAnonymousProvider()
        && resource.data.ownerId == uid
        && resource.data.reviewStatus == 'draft';
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
