rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAnonymousProvider() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function hasLinkedEmail(email) {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email == email;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && isAnonymousProvider()
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.role in ['candidate', 'company']
        && request.resource.data.accountStatus == 'pending'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if isOwner(uid)
        && resource.data.uid == uid
        && resource.data.role == request.resource.data.role
        && resource.data.accountStatus == 'pending'
        && request.resource.data.accountStatus == 'active'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email', 'accountStatus', 'updatedAt'])
        && request.resource.data.email is string
        && hasLinkedEmail(request.resource.data.email)
        && request.resource.data.updatedAt is timestamp;

      allow delete: if isOwner(uid)
        && resource.data.accountStatus == 'pending';
    }

    match /candidateProfiles/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && isAnonymousProvider()
        && request.resource.data.ownerId == uid
        && request.resource.data.reviewStatus == 'draft'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if isOwner(uid)
        && resource.data.ownerId == uid
        && request.resource.data.ownerId == uid
        && request.resource.data.reviewStatus == resource.data.reviewStatus;

      allow delete: if isOwner(uid)
        && resource.data.ownerId == uid
        && resource.data.reviewStatus == 'draft';
    }

    match /companyProfiles/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && isAnonymousProvider()
        && request.resource.data.ownerId == uid
        && request.resource.data.reviewStatus == 'draft'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if isOwner(uid)
        && resource.data.ownerId == uid
        && request.resource.data.ownerId == uid
        && request.resource.data.reviewStatus == resource.data.reviewStatus;

      allow delete: if isOwner(uid)
        && resource.data.ownerId == uid
        && resource.data.reviewStatus == 'draft';
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
